<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"> <androidx.cardview.widget.CardView
    android:layout_width="150dp" android:layout_height="150dp" app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    android:innerRadius="0dp"
    android:thicknessRatio="1"
    >
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_focus_logo"
        android:scaleType="centerCrop" /> </androidx.cardview.widget.CardView>

</LinearLayout>