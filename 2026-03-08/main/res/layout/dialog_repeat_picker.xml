<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/rounded_dialog_bg">

    <TextView
        android:id="@+id/dialog_repeat_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="반복 요일 설정"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="15dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btn_sun"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="일"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_mon"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="월"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_tue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="화"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_wed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="수"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_thu"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="목"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_fri"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="금"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_sat"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="토"
            android:textSize="14sp"
            android:background="@drawable/rounded_button_unselected"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/button_clear_repeat"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="반복 해제"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/button_repeat_cancel"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="취소"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/button_set_repeat"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="반복 설정"/>
    </LinearLayout>
</LinearLayout>